@inject TranslationService T
@inject DemoProjectService Demos
@inject IJSRuntime JS
@implements IDisposable

<!-- ═══════════════════════════════════════════════════════════
     PROJEKTE & LIVE-DEMOS
════════════════════════════════════════════════════════════ -->
<section id="demos" style="background: linear-gradient(180deg, rgba(var(--mud-palette-primary-rgb),0.07) 0%, transparent 100%); padding: 80px 0 40px;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudText Typo="Typo.overline" Color="Color.Primary" Style="letter-spacing:0.2em;">
            @T["nav.projects"]
        </MudText>
        <MudText Typo="Typo.h3" Class="gradient-text mt-1" Style="font-weight:700;">
            @T["demos.title"]
        </MudText>
        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2" Style="font-weight:400; max-width:640px;">
            @T["demos.subtitle"]
        </MudText>
    </MudContainer>
</section>

<MudContainer MaxWidth="MaxWidth.Large" Class="pb-16">
    <MudGrid Spacing="5">
        @foreach (var demo in _demos)
        {
            <MudItem xs="12" sm="6" lg="4">
                <div class="glass-card pf-reveal project-card @(demo.Status == "live" ? "project-card--highlighted" : "")"
                     style="height:100%; display:flex; flex-direction:column; padding:0; overflow:hidden;">

                    <div style="padding:24px 24px 16px;">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                            <div class="project-icon-wrap">
                                <MudIcon Icon="@MapIcon(demo.Icon)" Style="font-size:1.8rem; color: var(--color-primary);" />
                            </div>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@StatusColor(demo.Status)"
                                     Variant="@(demo.Status == "live" ? Variant.Filled : Variant.Outlined)"
                                     Style="font-size:0.7rem; height:22px;">
                                @StatusLabel(demo.Status)
                            </MudChip>
                        </div>

                        <MudText Typo="Typo.h6" Style="font-weight:700; line-height:1.3;">
                            @GetTitle(demo)
                        </MudText>

                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2" Style="line-height:1.65;">
                            @GetDescription(demo)
                        </MudText>
                    </div>

                    <div style="padding: 0 24px 16px; flex:1;">
                        <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:8px;">
                            @foreach (var tech in demo.TechStack)
                            {
                                <span class="skill-chip" style="font-size:0.75rem; padding:3px 10px;">@tech</span>
                            }
                        </div>
                    </div>

                    <div style="padding:16px 24px; border-top: 1px solid var(--glass-border); display:flex; gap:10px;">
                        @if (demo.LiveUrl is not null)
                        {
                            <MudButton Size="Size.Small"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.PlayArrow"
                                       Style="border-radius:8px; flex:1;"
                                       Href="@demo.LiveUrl" Target="_blank">
                                @T["demos.open"]
                            </MudButton>
                        }
                        @if (demo.RepoUrl is not null)
                        {
                            <MudButton Size="Size.Small"
                                       Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Custom.Brands.GitHub"
                                       Style="border-radius:8px; flex:1;"
                                       Href="@demo.RepoUrl" Target="_blank">
                                @T["demos.repo"]
                            </MudButton>
                        }
                        @if (demo.LiveUrl is null && demo.RepoUrl is null)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-style:italic;">
                                @StatusLabel(demo.Status) …
                            </MudText>
                        }
                    </div>
                </div>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    private IReadOnlyList<DemoProject> _demos = [];

    protected override async Task OnInitializedAsync()
    {
        T.OnLanguageChanged += Refresh;
        _demos = await Demos.GetAllAsync();
    }

    // Erneuter Aufruf nötig, da die Demo-Karten erst nach dem asynchronen
    // Laden von demos.json entstehen (pfInitReveal ist idempotent).
    protected override async Task OnAfterRenderAsync(bool firstRender)
        => await JS.InvokeVoidAsync("pfInitReveal");

    private string GetTitle(DemoProject d) => T.CurrentLanguage switch
    {
        "en" => d.TitleEn,
        "tr" => d.TitleTr,
        _    => d.TitleDe
    };

    private string GetDescription(DemoProject d) => T.CurrentLanguage switch
    {
        "en" => d.DescriptionEn,
        "tr" => d.DescriptionTr,
        _    => d.DescriptionDe
    };

    private string StatusLabel(string status) => status switch
    {
        "live"    => T["demos.status.live"],
        "dev"     => T["demos.status.dev"],
        _         => T["demos.status.planned"]
    };

    private static Color StatusColor(string status) => status switch
    {
        "live" => Color.Success,
        "dev"  => Color.Warning,
        _      => Color.Default
    };

    private static string MapIcon(string icon) => icon switch
    {
        "dashboard" => Icons.Material.Filled.Dashboard,
        "beach"     => Icons.Material.Filled.BeachAccess,
        "car"       => Icons.Material.Filled.DirectionsCar,
        "group"     => Icons.Material.Filled.Groups,
        "support"   => Icons.Material.Filled.SupportAgent,
        "chart"     => Icons.Material.Filled.BarChart,
        _           => Icons.Material.Filled.Widgets
    };

    private void Refresh() => StateHasChanged();

    public void Dispose() => T.OnLanguageChanged -= Refresh;
}
