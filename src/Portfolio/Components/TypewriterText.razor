@implements IDisposable

<span class="typewriter-container">
    <span class="typewriter-text">@_currentText</span><span class="typewriter-cursor">|</span>
</span>

@code {
    [Parameter]
    public List<string> Words { get; set; } = new()
    {
        "Software-Ingenieur",
        ".NET & C# Entwickler",
        "Automatisierungsspezialist",
        "Freelancer"
    };

    [Parameter]
    public int TypingSpeedMs { get; set; } = 100;

    [Parameter]
    public int DeletingSpeedMs { get; set; } = 50;

    [Parameter]
    public int PauseAfterTypingMs { get; set; } = 2000;

    [Parameter]
    public int PauseAfterDeletingMs { get; set; } = 500;

    private System.Threading.Timer? _timer;
    private int _wordIndex = 0;
    private int _charIndex = 0;
    private string _currentText = "";
    private bool _isDeleting = false;
    private bool _isDisposed = false;

    protected override void OnInitialized()
    {
        // Start typing after a short initial delay
        _timer = new System.Threading.Timer(OnTimerCallback, null, 500, System.Threading.Timeout.Infinite);
    }

    protected override void OnParametersSet()
    {
        if (Words == null || Words.Count == 0)
        {
            _currentText = "";
            return;
        }

        // Handle language change or word list update gracefully
        if (_wordIndex >= Words.Count)
        {
            _wordIndex = 0;
            _charIndex = 0;
            _currentText = "";
            _isDeleting = false;
        }
        else
        {
            // Clip indices to keep state safe
            _charIndex = Math.Min(_charIndex, Words[_wordIndex].Length);
            _currentText = Words[_wordIndex].Substring(0, _charIndex);
        }
    }

    private void OnTimerCallback(object? state)
    {
        if (_isDisposed) return;

        // Run on the UI thread to update state and trigger rendering
        _ = InvokeAsync(async () =>
        {
            await UpdateTypewriterState();
        });
    }

    private async Task UpdateTypewriterState()
    {
        if (_isDisposed || Words == null || Words.Count == 0) return;

        var currentWord = Words[_wordIndex];
        int nextDelay = TypingSpeedMs;

        if (!_isDeleting)
        {
            if (_charIndex < currentWord.Length)
            {
                _charIndex++;
                _currentText = currentWord.Substring(0, _charIndex);
                nextDelay = TypingSpeedMs;
            }
            else
            {
                // Finished typing, pause
                _isDeleting = true;
                nextDelay = PauseAfterTypingMs;
            }
        }
        else
        {
            if (_charIndex > 0)
            {
                _charIndex--;
                _currentText = currentWord.Substring(0, _charIndex);
                nextDelay = DeletingSpeedMs;
            }
            else
            {
                // Finished deleting, move to next word and pause
                _isDeleting = false;
                _wordIndex = (_wordIndex + 1) % Words.Count;
                _currentText = "";
                nextDelay = PauseAfterDeletingMs;
            }
        }

        StateHasChanged();

        // Reschedule timer
        try
        {
            if (!_isDisposed)
            {
                _timer?.Change(nextDelay, System.Threading.Timeout.Infinite);
            }
        }
        catch (ObjectDisposedException)
        {
            // Safe ignore if disposed during execution
        }
    }

    public void Dispose()
    {
        _isDisposed = true;
        _timer?.Dispose();
        _timer = null;
    }
}
