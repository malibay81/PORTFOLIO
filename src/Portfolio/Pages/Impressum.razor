@page "/impressum"

<PageTitle>Impressum | M. Ali Bayrak</PageTitle>

<div class="portfolio-page">
<MudContainer MaxWidth="MaxWidth.Medium" Class="py-12">
    <MudText Typo="Typo.h3" Class="gradient-text mb-6" Style="font-weight:700;">Impressum</MudText>

    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-6">
        Entwurf / Platzhalter – bitte die mit […] markierten Angaben ergänzen und vor
        Veröffentlichung rechtlich prüfen lassen (z. B. e-recht24 oder Anwalt).
    </MudAlert>

    <MudText Typo="Typo.h6" Class="mt-4 mb-1" Style="font-weight:700;">Angaben gemäß § 5 DDG</MudText>
    <MudText Typo="Typo.body1">
        Muhammed Ali Bayrak<br />
        [Straße und Hausnummer]<br />
        [PLZ Ort]<br />
        Deutschland
    </MudText>

    <MudText Typo="Typo.h6" Class="mt-6 mb-1" Style="font-weight:700;">Kontakt</MudText>
    <MudText Typo="Typo.body1">
        E-Mail: mali.bayrak@web.de<br />
        Telefon: [optional]
    </MudText>

    <MudText Typo="Typo.h6" Class="mt-6 mb-1" Style="font-weight:700;">Verantwortlich für den Inhalt</MudText>
    <MudText Typo="Typo.body1">
        Muhammed Ali Bayrak (Anschrift wie oben)
    </MudText>

    <MudText Typo="Typo.h6" Class="mt-6 mb-1" Style="font-weight:700;">Haftung für Inhalte &amp; Links</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Als Diensteanbieter bin ich für eigene Inhalte auf diesen Seiten nach den allgemeinen
        Gesetzen verantwortlich. Für Inhalte externer Links sind ausschließlich deren Betreiber
        verantwortlich; zum Zeitpunkt der Verlinkung waren keine Rechtsverstöße erkennbar.
    </MudText>
</MudContainer>
</div>
